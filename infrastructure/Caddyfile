firecrawl.bigalexn8n.ru {
    tls alexei.bigalex@yandex.ru

    # Главная страница → редирект на админку
    redir / /admin/30ca580d45d754fa7f22780c3ff69aa9/queues

    # Админ-панель очередей (защищена basicauth)
    @firecrawl_admin path /admin/*
    handle @firecrawl_admin {
        basicauth {
            bigalex $2a$14$3xGvIHCMQyjQkc03Da8hReYsv8pQJfV3NMHIsrgKLu0gu4D82QqGu
        }
        reverse_proxy 127.0.0.1:3002
    }

    # API без аутентификации (для MCP и n8n)
    handle {
        reverse_proxy 127.0.0.1:3002
    }
}

