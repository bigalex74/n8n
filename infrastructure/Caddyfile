bigalexn8n.ru {
    tls alexei.bigalex@yandex.ru

    # Portal (infrastructure dashboard)
    handle /portal/* {
        uri strip_prefix /portal
        root * /home/user/n8n-docker/portal
        try_files {path} /index.html
        file_server
        encode zstd gzip
    }

    # Portal API server
    handle /portal-api/* {
        uri strip_prefix /portal-api
        reverse_proxy 127.0.0.1:3080
    }

    # Исключение для Telegram webhook (без аутентификации)
    @telegram_webhook {
        path /webhook/telegram*
        path /webhook/*
    }

    handle @telegram_webhook {
        reverse_proxy 127.0.0.1:5678
    }

    # Все остальные запросы проксируем на n8n
    handle {
        reverse_proxy 127.0.0.1:5678
    }
}

