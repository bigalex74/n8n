portal.bigalexn8n.ru {
    tls alexei.bigalex@yandex.ru

    # Admin panel — proxied to API server (handles auth + dynamic content)
    handle /admin* {
        reverse_proxy 127.0.0.1:3080
    }

    # API (both /api/* and /portal-api/* for frontend compatibility)
    handle /api/* {
        reverse_proxy 127.0.0.1:3080
    }

    handle /portal-api/* {
        uri strip_prefix /portal-api
        reverse_proxy 127.0.0.1:3080
    }

    # Static files (index.html etc)
    handle {
        root * /home/user/n8n-docker/portal
        try_files {path} /index.html
        file_server
        encode zstd gzip
    }
}
