[{"updatedAt":"2026-04-03T04:38:05.834Z","createdAt":"2026-03-31T18:57:14.347Z","id":"AW58nseQdLtJn5ZO","name":"sub_lightrag_api","description":null,"active":true,"isArchived":false,"nodes":[{"parameters":{"jsCode":"const action = $input.first().json.action;\nlet url = '';\nlet method = '';\nlet body = {};\n\nswitch (action) {\n  case 'clear':\n    method='DELETE';\n    url='https://lightrag.bigalexn8n.ru/documents';\n    break;\n  case 'insertText':\n    method='POST';\n    url='https://lightrag.bigalexn8n.ru/documents/text';\n    body.text = $input.first().json.text;\n    body.file_source = $input.first().json.meta_data;\n    break;\n  case 'deleteChunks':\n    method='DELETE';\n    url='https://lightrag.bigalexn8n.ru/documents/delete_document';\n    body.doc_ids = [];\n    body.delete_file = false;\n    body.delete_llm_cache = false;\n    break;\n  case 'insertTexts':\n    method='POST';\n    url='https://lightrag.bigalexn8n.ru/documents/texts';\n    body.texts = $input.first().json.texts;\n    body.file_sources = JSON.parse($input.first().json.meta_data);\n    break;\n  case 'query':\n    method='POST';\n    url='https://lightrag.bigalexn8n.ru/query';\n    body.query=`Проанализируй корейский текст ниже. Найди в базе знаний факты о персонажах, их поле, локациях и терминах.\n\n### ПРАВИЛА ОФОРМЛЕНИЯ СПРАВКИ:\n1. ВСЕ имена и названия должны быть ТОЛЬКО на русском языке. \n2. Если есть имя на корейском языке - транслитерируй его на русский язык самостоятельно (например, 이사영 -> И Саён). \n3. НЕ оставляй корейских символов в итоговом списке.\n4. Объединяй все факты об одном персонаже в один пункт.\n5. НЕ пиши фразы типа 'персонаж, к которому относится имя'. Пиши сразу суть.\n\n### ФОРМАТ ОТВЕТА (СПИСОК):\n - [Имя на русском]: [пол, краткая роль и характеристика]\n - [Связь]: [отношения между героями на русском]\n - [Факт]: [событие на русском]\n - [Локация на русском]: [описание локации]`;\n    body.mode = \"mix\";\n    body.top_k = 20;\n    body.max_total_tokens = 1500;\n    body.response_type = 'Single Paragraph';\n    body.user_prompt = `Текст:\n    ${$input.first().json.text}`\n  default:\n    break;\n}\nreturn {url, method, body}"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[-272,-16],"id":"69a9e608-222c-48ab-a4d1-673cfd07fc92","name":"Code in JavaScript"},{"parameters":{"workflowInputs":{"values":[{"name":"action"},{"name":"text"},{"name":"texts","type":"array"},{"name":"meta_data"}]}},"type":"n8n-nodes-base.executeWorkflowTrigger","typeVersion":1.1,"position":[-448,-16],"id":"ffd9ce3c-ff28-40dd-9e04-af1ba1b179d5","name":"Start Workflow"},{"parameters":{"method":"={{ $json.method }}","url":"={{ $json.url }}","authentication":"genericCredentialType","genericAuthType":"httpHeaderAuth","sendHeaders":true,"headerParameters":{"parameters":[{"name":"accept","value":"application/json"},{"name":"Content-Type","value":"application/json"}]},"options":{}},"id":"28a4e7ec-0243-4a6f-9e7d-a2486e771049","name":"LightRAG API without body","type":"n8n-nodes-base.httpRequest","typeVersion":4.1,"position":[320,-160],"credentials":{"httpHeaderAuth":{"id":"04F0dXlIVNesjJse","name":"LightRag"}},"continueOnFail":true},{"parameters":{"method":"={{ $('Code in JavaScript').first().json.method }}","url":"={{ $('Code in JavaScript').first().json.url }}","authentication":"genericCredentialType","genericAuthType":"httpHeaderAuth","sendHeaders":true,"headerParameters":{"parameters":[{"name":"accept","value":"application/json"},{"name":"Content-Type","value":"application/json"}]},"sendBody":true,"specifyBody":"json","jsonBody":"={{ JSON.stringify($('Code in JavaScript').first().json.body) }}","options":{}},"id":"70b1cd48-76c1-43f6-ae38-21ca034d5846","name":"LightRAG API with body","type":"n8n-nodes-base.httpRequest","typeVersion":4.1,"position":[320,32],"credentials":{"httpHeaderAuth":{"id":"04F0dXlIVNesjJse","name":"LightRag"}},"continueOnFail":true},{"parameters":{"method":"=GET","url":"=https://lightrag.bigalexn8n.ru/documents/track_status